    <style>
      /* ---- Menu Page Styles ---- */
      .menu-page-hero {
        background-color: var(--eerie-black-1);
        padding-block: 120px 60px;
        text-align: center;
      }

      /* Sticky Category Nav */
      .menu-cat-nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background-color: var(--eerie-black-2, #1a1a1a);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding-block: 0;
        overflow-x: auto;
        scrollbar-width: none;
      }

      .menu-cat-nav::-webkit-scrollbar {
        display: none;
      }

      .menu-cat-nav ul {
        display: flex;
        gap: 0;
        list-style: none;
        padding: 0;
        margin: 0;
        justify-content: center;
        flex-wrap: nowrap;
        min-width: max-content;
        margin-inline: auto;
      }

      .menu-cat-nav ul li a {
        display: block;
        padding: 16px 20px;
        color: var(--quick-silver, #aaa);
        font-size: 1.3rem;
        font-family: var(--fontFamily-dm_sans, "DM Sans", sans-serif);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none;
        white-space: nowrap;
        transition:
          color 0.2s,
          border-bottom 0.2s;
        border-bottom: 3px solid transparent;
      }

      .menu-cat-nav ul li a:hover,
      .menu-cat-nav ul li a.active {
        color: var(--gold-crayola, #c9a84c);
        border-bottom: 3px solid var(--gold-crayola, #c9a84c);
      }

      /* Menu Content */
      .menu-page-content {
        background-color: var(--eerie-black-1, #111);
        padding-block: 60px 100px;
      }

      .menu-section {
        margin-bottom: 80px;
        scroll-margin-top: 70px;
      }

      .menu-section-title {
        font-family: var(--fontFamily-forum, "Forum", serif);
        font-size: 3.8rem;
        color: var(--gold-crayola, #c9a84c);
        text-align: center;
        margin-bottom: 12px;
      }

      .menu-section-divider {
        width: 60px;
        height: 2px;
        background: var(--gold-crayola, #c9a84c);
        margin: 0 auto 40px;
        border: none;
      }

      .menu-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px 30px;
      }

      .menu-card {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        padding: 20px;
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 16px;
        background-color: rgba(255, 255, 255, 0.02);
        transition:
          background 0.25s,
          border-color 0.25s;
      }

      .menu-card:hover {
        background-color: rgba(255, 255, 255, 0.05);
        border-color: rgba(201, 168, 76, 0.3);
      }

      .menu-thumb-placeholder {
        min-width: 90px;
        width: 90px;
        height: 90px;
        border-radius: 50%;
        border: 2px dashed var(--gold-crayola, #c9a84c);
        background: rgba(255, 255, 255, 0.03);
        flex-shrink: 0;
        overflow: hidden;
      }

      .menu-thumb-placeholder img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
      }

      .menu-card-content {
        flex: 1;
      }

      .menu-card .title-wrapper {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 6px;
      }

      .menu-card .card-title {
        color: var(--white, #fff);
        font-size: 1.7rem;
        font-weight: 700;
        text-decoration: none;
      }

      .menu-card .card-title:hover {
        color: var(--gold-crayola, #c9a84c);
      }

      .menu-card .price {
        margin-left: auto;
        color: var(--gold-crayola, #c9a84c);
        font-size: 1.5rem;
        font-weight: 700;
        white-space: nowrap;
      }

      .menu-card .card-desc {
        color: var(--quick-silver, #999);
        font-size: 1.35rem;
        line-height: 1.65;
      }

      @media (max-width: 768px) {
        .menu-grid {
          grid-template-columns: 1fr;
        }
        .menu-cat-nav ul {
          justify-content: flex-start;
        }
        .menu-section-title {
          font-size: 2.8rem;
        }
      }
    </style>
