<!-- OPTION 1: Bottom Sheet + Sticky Sub-tabs -->
<!-- Replace your existing category circles + sub-tab row with this -->

<style>
  /* ===== STICKY HEADER ===== */
  .menu-sticky-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #1a1a1a;
    border-bottom: 1px solid #333;
  }

  /* Active cuisine bar */
  .active-cuisine-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    cursor: pointer;
    background: #2a2a2a;
  }
  .active-cuisine-bar .cuisine-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    font-weight: 700;
    color: #f5c842;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .active-cuisine-bar .chevron {
    font-size: 12px;
    color: #aaa;
    transition: transform 0.3s;
  }
  .active-cuisine-bar .chevron.open {
    transform: rotate(180deg);
  }

  /* Sub-category scroll tabs */
  .subcategory-tabs {
    display: flex;
    overflow-x: auto;
    gap: 0;
    scrollbar-width: none;
    background: #111;
  }
  .subcategory-tabs::-webkit-scrollbar {
    display: none;
  }
  .subcategory-tabs a {
    flex-shrink: 0;
    padding: 10px 16px;
    font-size: 12px;
    font-weight: 600;
    color: #888;
    text-decoration: none;
    letter-spacing: 0.8px;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: all 0.2s;
  }
  .subcategory-tabs a.active,
  .subcategory-tabs a:hover {
    color: #f5c842;
    border-bottom-color: #f5c842;
  }

  /* ===== BOTTOM SHEET OVERLAY ===== */
  .sheet-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    z-index: 200;
    align-items: flex-end;
  }
  .sheet-overlay.open {
    display: flex;
  }

  .bottom-sheet {
    background: #1c1c1c;
    border-radius: 20px 20px 0 0;
    width: 100%;
    max-height: 80vh;
    overflow-y: auto;
    padding: 0 16px 32px;
    animation: slideUp 0.3s ease;
  }
  @keyframes slideUp {
    from {
      transform: translateY(100%);
    }
    to {
      transform: translateY(0);
    }
  }

  .sheet-handle {
    width: 40px;
    height: 4px;
    background: #444;
    border-radius: 2px;
    margin: 12px auto 20px;
  }
  .sheet-title {
    font-size: 12px;
    color: #888;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 16px;
    padding-left: 4px;
  }

  /* Cuisine cards in sheet */
  .cuisine-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    border-radius: 14px;
    margin-bottom: 10px;
    background: #2a2a2a;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.2s;
  }
  .cuisine-card.active,
  .cuisine-card:hover {
    border-color: #f5c842;
    background: #2e2a1a;
  }
  .cuisine-card .card-emoji {
    font-size: 28px;
  }
  .cuisine-card .card-info h3 {
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 3px;
  }
  .cuisine-card .card-info p {
    font-size: 12px;
    color: #888;
    margin: 0;
  }
  .cuisine-card .card-arrow {
    margin-left: auto;
    color: #f5c842;
    font-size: 18px;
  }
</style>

<!-- Sticky Header: Active Cuisine + Sub-tabs -->
<div class="menu-sticky-header">
  <div class="active-cuisine-bar" onclick="toggleSheet()">
    <div class="cuisine-label">
      <span id="active-emoji">🇮🇳</span>
      <span id="active-name">Indian Food</span>
    </div>
    <span class="chevron" id="chevron">▼</span>
  </div>
  <nav class="subcategory-tabs" id="subcategory-tabs">
    <a href="#appetizers" class="active">Appetizers</a>
    <a href="#salads">Salads</a>
    <a href="#house-made-soups">Soups</a>
    <a href="#masalas-curries">Masalas & Curries</a>
    <a href="#tandoori">Tandoori</a>
    <a href="#biryani">Biryani</a>
    <a href="#modern-indian">Modern Indian</a>
  </nav>
</div>

<!-- Bottom Sheet Overlay -->
<div class="sheet-overlay" id="sheetOverlay" onclick="closeSheet(event)">
  <div class="bottom-sheet">
    <div class="sheet-handle"></div>
    <p class="sheet-title">Choose Cuisine</p>

    <div
      class="cuisine-card active"
      onclick="selectCuisine('🇮🇳', 'Indian Food', indianTabs)"
    >
      <span class="card-emoji">🇮🇳</span>
      <div class="card-info">
        <h3>Indian Food</h3>
        <p>Appetizers · Curries · Biryani · Tandoori</p>
      </div>
      <span class="card-arrow">›</span>
    </div>
    <div
      class="cuisine-card"
      onclick="selectCuisine('🇪🇹', 'Ethiopian Food', ethiopianTabs)"
    >
      <span class="card-emoji">🇪🇹</span>
      <div class="card-info">
        <h3>Ethiopian Food</h3>
        <p>Vegetarian · Meat Dishes · Combo Plates</p>
      </div>
      <span class="card-arrow">›</span>
    </div>
    <div
      class="cuisine-card"
      onclick="selectCuisine('🧇', 'Brunch Specialities', brunchTabs)"
    >
      <span class="card-emoji">🧇</span>
      <div class="card-info">
        <h3>Brunch Specialities</h3>
        <p>Weekend Brunch · Egg Dishes · Drinks</p>
      </div>
      <span class="card-arrow">›</span>
    </div>
    <div
      class="cuisine-card"
      onclick="selectCuisine('🍹', 'Bar Menu', barTabs)"
    >
      <span class="card-emoji">🍹</span>
      <div class="card-info">
        <h3>Bar Menu</h3>
        <p>Cocktails · Spirits · Wine · Beer</p>
      </div>
      <span class="card-arrow">›</span>
    </div>
    <div
      class="cuisine-card"
      onclick="selectCuisine('☕', 'Drinks', drinksTabs)"
    >
      <span class="card-emoji">☕</span>
      <div class="card-info">
        <h3>Drinks</h3>
        <p>Hot · Cold · Juices · Smoothies</p>
      </div>
      <span class="card-arrow">›</span>
    </div>
    <div
      class="cuisine-card"
      onclick="selectCuisine('🍰', 'Desserts', dessertsTabs)"
    >
      <span class="card-emoji">🍰</span>
      <div class="card-info">
        <h3>Desserts</h3>
        <p>Indian Sweets · Western Desserts</p>
      </div>
      <span class="card-arrow">›</span>
    </div>
  </div>
</div>

<script>
  // Define sub-tabs per cuisine — fill in your actual anchor IDs
  const indianTabs = [
    { label: "Appetizers", href: "#appetizers" },
    { label: "Salads", href: "#salads" },
    { label: "Soups", href: "#house-made-soups" },
    { label: "Masalas & Curries", href: "#masalas-curries" },
    { label: "Tandoori", href: "#tandoori" },
    { label: "Biryani", href: "#biryani" },
    { label: "Modern Indian", href: "#modern-indian" },
  ];
  const ethiopianTabs = [
    { label: "Vegetarian", href: "#eth-veg" },
    { label: "Meat Dishes", href: "#eth-meat" },
    { label: "Combo Plates", href: "#eth-combo" },
  ];
  const brunchTabs = [
    { label: "Brunch", href: "#brunch" },
    { label: "Egg Dishes", href: "#eggs" },
    { label: "Brunch Drinks", href: "#brunch-drinks" },
  ];
  const barTabs = [
    { label: "Cocktails", href: "#cocktails" },
    { label: "Wine", href: "#wine" },
    { label: "Beer", href: "#beer" },
    { label: "Spirits", href: "#spirits" },
  ];
  const drinksTabs = [
    { label: "Hot", href: "#hot-drinks" },
    { label: "Cold", href: "#cold-drinks" },
    { label: "Juices", href: "#juices" },
  ];
  const dessertsTabs = [
    { label: "Indian Sweets", href: "#indian-sweets" },
    { label: "Western", href: "#western-desserts" },
  ];

  function toggleSheet() {
    const overlay = document.getElementById("sheetOverlay");
    const chevron = document.getElementById("chevron");
    overlay.classList.toggle("open");
    chevron.classList.toggle("open");
  }
  function closeSheet(e) {
    if (e.target === document.getElementById("sheetOverlay")) toggleSheet();
  }
  function selectCuisine(emoji, name, tabs) {
    document.getElementById("active-emoji").textContent = emoji;
    document.getElementById("active-name").textContent = name;
    const nav = document.getElementById("subcategory-tabs");
    nav.innerHTML = tabs
      .map(
        (t, i) =>
          `<a href="${t.href}" class="${i === 0 ? "active" : ""}">${t.label}</a>`,
      )
      .join("");
    toggleSheet();
  }
</script>
